{
  // --- MONACO EDITOR SETTINGS ---
  // "base": Defines the base theme style ('vs-dark' or 'vs')
  "base": "vs-dark",
  // "inherit": If true, inherits base Monaco colors
  "inherit": true,
  // "rules": Defines syntax highlighting colors for code tokens
  "rules": [
    { "token": "comment", "foreground": "#2e3a5a", "fontStyle": "italic" },
    { "token": "string", "foreground": "#00e5ff" },
    { "token": "keyword", "foreground": "#ff00ff" },
    { "token": "storage.type", "foreground": "#ff00ff" },
    { "token": "entity.name.function", "foreground": "#ffffff" },
    { "token": "variable", "foreground": "#b0c4de" },
    { "token": "entity.name.class", "foreground": "#ffffff" },
    { "token": "constant.numeric", "foreground": "#ff9f00" },
    { "token": "entity.name.tag", "foreground": "#00e5ff" },
    { "token": "keyword.operator", "foreground": "#00e5ff" }
  ],
  // "colors": Defines visual colors within the Monaco editor area
  "colors": {
    "editor.background": "#05060a",
    "editor.foreground": "#b0c4de",
    "editor.lineHighlightBackground": "#0c1018",
    "editorCursor.foreground": "#ff00ff",
    "editorWhitespace.foreground": "#1a253a"
  },
  // --- FLUTTER UI SETTINGS ---
  // These values control the colors of the application widgets (Sidebar, Tabs, etc.)
  // IMPORTANT: Must be integer values (ARGB) representing color in 0xAARRGGBB format
  "ui": {
    "bg": "#05060A", // Main background
    "bgForeground": "#B0C4DE", // Main Foreground
    "activityBar": "#05060A", // Activity Bar
    "activityBarForeground": "#00E5FF", // Activity bar foreground
    "sidebar": "#05060A", // File explorer and others panels background
    "sidebarForeground": "#B0C4DE", // File explorer and others panels foreground
    "tabBar": "#05060A", // Tab bar
    "tabBarForeground": "#B0C4DE", // Tab bar foreground
    "tabActive": "#080C1C", // Active tab
    "tabActiveForeground": "#00E5FF", // Active tab foreground
    "tabInactive": "#05060A", // inActive tab
    "tabInactiveForeground": "#60709A", // inActive tab foreground
    "statusBar": "#00E5FF", // Status bar background
    "statusBarForeground": "#00E5FF" // Status bar Foreground
  }
}

